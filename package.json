{
  "name": "zerogravity-monorepo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "prepare": "husky",
    "build:shared": "pnpm --filter shared build",
    "build:web": "pnpm --filter ...web build",
    "build:extension": "pnpm --filter ...extension build",
    "build:all": "pnpm -r build",
    "dev:shared": "pnpm --filter shared dev",
    "dev:web": "pnpm --filter web dev",
    "dev:extension": "pnpm --filter extension dev",
    "lint:shared": "pnpm --filter shared lint",
    "lint:web": "pnpm --filter web lint",
    "lint:extension": "pnpm --filter extension lint",
    "lint:all": "pnpm -r lint",
    "lint:fix": "eslint . --ext ts,tsx,js,jsx --fix",
    "format": "prettier --write \"packages/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"packages/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "type-check:shared": "pnpm --filter shared type-check",
    "type-check:web": "pnpm --filter web type-check",
    "type-check:extension": "pnpm --filter extension type-check",
    "type-check:all": "pnpm -r type-check",
    "analyze:web": "pnpm --filter web analyze",
    "test:web": "pnpm --filter web test",
    "test:web:watch": "pnpm --filter web test:watch",
    "test:web:coverage": "pnpm --filter web test:coverage",
    "test:shared": "pnpm --filter @zerogravity/shared test:run",
    "test:shared:watch": "pnpm --filter @zerogravity/shared test",
    "test:shared:coverage": "pnpm --filter @zerogravity/shared test:coverage",
    "test:all": "pnpm test:shared && pnpm test:web",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "start:web": "pnpm --filter web start",
    "start:extension": "pnpm --filter extension start",
    "start:all": "pnpm -r start"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@playwright/test": "^1.56.1",
    "@typescript-eslint/eslint-plugin": "^8.36.0",
    "@typescript-eslint/parser": "^8.36.0",
    "autoprefixer": "^10.4.21",
    "commitlint": "^19.8.1",
    "commitlint-config-gitmoji": "^2.3.1",
    "eslint": "^8",
    "eslint-config-prettier": "^10.1.5",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.1",
    "eslint-plugin-react-hooks": "^5.1.0",
    "gitmoji-cli": "^9.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.2",
    "playwright": "^1.56.1",
    "postcss": "^8.5.6",
    "prettier": "3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "tailwindcss": "^4.1.12",
    "typescript": "^5"
  }
}
