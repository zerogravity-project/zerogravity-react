{
  "manifest_version": 3,
  "name": "Zero Gravity",
  "version": "1.0.0",
  "description": "ZeroGravity Emotion Tracking - New Tab Extension",
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "permissions": ["storage", "cookies"],
  "host_permissions": ["http://localhost:3000/*", "https://zerogravity.app/*"]
}
